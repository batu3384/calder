#!/usr/bin/env sh

set -eu

if [ "${CALDER_SKIP_PRE_PUSH:-0}" = "1" ]; then
  echo "[pre-push] CALDER_SKIP_PRE_PUSH=1 set, skipping checks."
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

echo "[pre-push] Running Calder quality gates..."
echo "[pre-push] 1/5: npm run audit:structure"
npm run audit:structure

echo "[pre-push] 2/5: npm run lint"
npm run lint

echo "[pre-push] 3/5: npm run format:check"
npm run format:check

echo "[pre-push] 4/5: npm run build"
npm run build

echo "[pre-push] 5/5: npm test"
npm test

echo "[pre-push] PASS - push allowed."
