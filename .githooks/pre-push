#!/usr/bin/env sh

set -eu

if [ "${CALDER_SKIP_PRE_PUSH:-0}" = "1" ]; then
  echo "[pre-push] CALDER_SKIP_PRE_PUSH=1 set, skipping checks."
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

echo "[pre-push] Running Calder quality gates..."
echo "[pre-push] 1/3: npm run audit:structure"
npm run audit:structure

echo "[pre-push] 2/3: npm run build"
npm run build

echo "[pre-push] 3/3: npm test"
npm test

echo "[pre-push] PASS - push allowed."
