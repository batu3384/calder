{
  "name": "calder",
  "productName": "Calder",
  "version": "0.2.25",
  "description": "A terminal-centric IDE for AI-powered CLI tools, built on Electron",
  "author": {
    "name": "Batuhan Yuksel"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/batu3384/calder.git"
  },
  "homepage": "https://github.com/batu3384/calder",
  "bugs": {
    "url": "https://github.com/batu3384/calder/issues"
  },
  "bin": {
    "calder": "bin/calder.js"
  },
  "keywords": [
    "electron",
    "ide",
    "terminal",
    "ai",
    "developer-tools",
    "coding-agents",
    "terminal-ide",
    "multi-session"
  ],
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/main/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && npm run build:renderer && npm run copy-assets",
    "build:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap --loader:.ts=ts",
    "copy-assets": "node scripts/copy-assets.js",
    "start": "npm run build && node scripts/run-electron.js",
    "dev": "npm run build && node scripts/run-electron.js",
    "postinstall": "node -e \"try{require('electron-builder/package.json');require('child_process').execSync('electron-builder install-app-deps',{stdio:'inherit'})}catch{}\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:critical-stability": "vitest run src/renderer/components/custom-select.test.ts src/renderer/components/cli-surface/quick-setup.test.ts src/renderer/components/tab-bar-command-deck.test.ts src/renderer/components/browser-tab-pane.test.ts src/renderer/components/mosaic-resize.test.ts src/renderer/components/surface-routing.test.ts"
  },
  "build": {
    "appId": "com.batuhanyuksel.calder",
    "productName": "Calder",
    "icon": "build/icon.png",
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleDisplayName": "Calder",
        "CFBundleName": "Calder"
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "batuhanyuksel",
      "repo": "calder",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.7",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.0",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.5",
    "node-pty": "^1.1.0",
    "picomatch": "^4.0.4"
  },
  "overrides": {
    "hono": "^4.12.14"
  }
}
