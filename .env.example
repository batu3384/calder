# Calder ortam değişkenleri (örnek — gerçek değerleri buraya yazmayın)
# Bu dosyayı kopyalayıp .env oluşturabilirsiniz; .env git'e girmez.

# Provider kimlik bilgileri (login shell / sistem ortamından da okunur)
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# DASHSCOPE_API_KEY=

# Calder CLI indirme güvenliği (opsiyonel)
# CALDER_REQUIRE_CHECKSUM=1

# CI / geliştirme
# CALDER_SKIP_APP_DEPS=1
